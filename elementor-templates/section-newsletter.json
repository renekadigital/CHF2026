{
  "version": "0.4",
  "title": "CHF Newsletter Signup Section",
  "type": "section",
  "content": [
    {
      "id": "nws0001",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "flex_direction": "column",
        "flex_justify_content": "center",
        "flex_align_items": "center",
        "background_background": "gradient",
        "background_color": "#0f1a2e",
        "background_color_b": "#1B2A4A",
        "background_gradient_type": "linear",
        "background_gradient_angle": { "unit": "deg", "size": 135 },
        "background_gradient_position": "center center",
        "background_color_stop": { "unit": "%", "size": 0 },
        "background_color_b_stop": { "unit": "%", "size": 50 },
        "border_border": "solid",
        "border_width": { "unit": "px", "top": "3", "right": "0", "bottom": "0", "left": "0", "isLinked": false },
        "border_color": "#56B84A",
        "padding": { "unit": "px", "top": "88", "right": "24", "bottom": "88", "left": "24", "isLinked": false },
        "position": "relative",
        "css_classes": "chf-newsletter",
        "_element_custom_css": ".chf-newsletter::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse at 30% 20%, rgba(86,184,74,0.06) 0%, transparent 50%), radial-gradient(ellipse at 70% 80%, rgba(201,168,76,0.04) 0%, transparent 50%); pointer-events: none; z-index: 0; } .chf-newsletter { background-size: 200% 200%; }"
      },
      "elements": [
        {
          "id": "nws0002",
          "elType": "container",
          "settings": {
            "content_width": "boxed",
            "boxed_width": { "unit": "px", "size": 640 },
            "flex_direction": "column",
            "flex_align_items": "center",
            "flex_justify_content": "center",
            "flex_gap": { "unit": "px", "size": 24 },
            "position": "relative",
            "z_index": 1,
            "width": { "unit": "%", "size": 100 }
          },
          "elements": [
            {
              "id": "nws0003",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Stay Connected",
                "header_size": "h2",
                "align": "center",
                "title_color": "#FFFFFF",
                "typography_typography": "custom",
                "typography_font_family": "Merriweather",
                "typography_font_size": { "unit": "px", "size": 32 },
                "typography_font_size_tablet": { "unit": "px", "size": 28 },
                "typography_font_size_mobile": { "unit": "px", "size": 24 },
                "typography_font_weight": "700",
                "typography_line_height": { "unit": "em", "size": 1.3 }
              },
              "elements": []
            },
            {
              "id": "nws0004",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Get the latest insights on Houston's future delivered to your inbox. Research reports, event invitations, and policy updates from our cross-sector network.</p>",
                "align": "center",
                "text_color": "rgba(255,255,255,0.65)",
                "typography_typography": "custom",
                "typography_font_family": "Inter",
                "typography_font_size": { "unit": "px", "size": 15 },
                "typography_line_height": { "unit": "em", "size": 1.7 },
                "typography_font_weight": "400",
                "max_width": { "unit": "px", "size": 480 },
                "margin": { "unit": "px", "top": "0", "right": "auto", "bottom": "0", "left": "auto", "isLinked": false }
              },
              "elements": []
            },
            {
              "id": "nws0005",
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "Newsletter Signup",
                "form_fields": [
                  {
                    "_id": "ff00001",
                    "field_type": "email",
                    "field_label": "Email Address",
                    "placeholder": "Enter your email address",
                    "required": "true",
                    "width": "75",
                    "field_label_show": "false",
                    "css_classes": "chf-newsletter__email"
                  },
                  {
                    "_id": "ff00002",
                    "field_type": "submit",
                    "field_label": "Subscribe",
                    "button_text": "Subscribe",
                    "width": "25",
                    "css_classes": "chf-newsletter__submit"
                  }
                ],
                "input_size": "md",
                "show_labels": "false",
                "button_text": "Subscribe",
                "button_size": "md",
                "button_width": "100",
                "button_align": "stretch",
                "button_color": "#FFFFFF",
                "button_background_color": "#56B84A",
                "button_hover_color": "#FFFFFF",
                "button_background_hover_color": "#3d8f35",
                "button_typography_typography": "custom",
                "button_typography_font_family": "Inter",
                "button_typography_font_size": { "unit": "px", "size": 12 },
                "button_typography_font_weight": "700",
                "button_typography_text_transform": "uppercase",
                "button_typography_letter_spacing": { "unit": "px", "size": 0.5 },
                "field_text_color": "rgba(255,255,255,0.85)",
                "field_placeholder_color": "rgba(255,255,255,0.4)",
                "field_background_color": "rgba(255,255,255,0.1)",
                "field_border_color": "rgba(255,255,255,0.2)",
                "field_border_width": { "unit": "px", "size": 1 },
                "field_border_radius": { "unit": "px", "size": 0 },
                "field_typography_typography": "custom",
                "field_typography_font_family": "Inter",
                "field_typography_font_size": { "unit": "px", "size": 14 },
                "column_gap": { "unit": "px", "size": 0 },
                "row_gap": { "unit": "px", "size": 0 },
                "email_to": "info@futurehouston.org",
                "email_subject": "New Newsletter Subscriber",
                "form_layout": "inline",
                "css_classes": "chf-newsletter__form",
                "_element_custom_css": ".chf-newsletter__form .elementor-field-group:first-child .elementor-field { border-radius: 28px 0 0 28px; padding: 12px 20px; border-right: none; } .chf-newsletter__form .elementor-field-group:last-child .elementor-button { border-radius: 0 28px 28px 0; padding: 12px 24px; height: 100%; } .chf-newsletter__form .elementor-form-fields-wrapper { display: flex; flex-direction: row; } .chf-newsletter__form .elementor-field:focus { border-color: #56B84A; background: rgba(255,255,255,0.14); outline: none; } @media (max-width: 768px) { .chf-newsletter__form .elementor-field-group:first-child .elementor-field { border-radius: 28px; border-right: 1px solid rgba(255,255,255,0.2); margin-bottom: 12px; } .chf-newsletter__form .elementor-field-group:last-child .elementor-button { border-radius: 28px; } .chf-newsletter__form .elementor-form-fields-wrapper { flex-direction: column; } }"
              },
              "elements": []
            },
            {
              "id": "nws0006",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>We respect your privacy. Unsubscribe at any time.</p>",
                "align": "center",
                "text_color": "rgba(255,255,255,0.4)",
                "typography_typography": "custom",
                "typography_font_family": "Inter",
                "typography_font_size": { "unit": "px", "size": 12 },
                "typography_line_height": { "unit": "em", "size": 1.5 },
                "typography_font_weight": "400"
              },
              "elements": []
            }
          ]
        }
      ]
    }
  ],
  "page_settings": {},
  "metadata": {
    "wp_page_template": "default"
  }
}