  <item>
    <title><![CDATA[Project Metis: Brain Health Summit]]></title>
    <link>https://centerforhoustonsfuture.org/events/brain-health-summit/</link>
    <dc:creator><![CDATA[admin]]></dc:creator>
    <content:encoded><![CDATA[<div style="padding:80px var(--container-pad);max-width:900px;margin:auto;">

    <div class="reveal" style="margin-bottom:32px;padding:24px 28px;background:var(--off);border-radius:var(--radius-md);border:1px solid var(--rule);display:flex;flex-direction:column;gap:12px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <svg style="width:18px;height:18px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span style="color:var(--text);font-weight:600;">9:00 AM &ndash; 12:00 PM</span>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <svg style="width:18px;height:18px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span style="color:var(--mid);">Partnership Tower, 701 Avenida de las Americas, Suite 900, Houston</span>
      </div>
      <a href="#register" style="margin-top:8px;display:inline-flex;align-self:flex-start;padding:12px 28px;background:var(--navy);color:var(--white);text-decoration:none;font-weight:700;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;border-radius:var(--radius-pill);transition:background 0.2s,box-shadow 0.2s;">
        Register Now <span aria-hidden="true" style="margin-left:6px;">&#8594;</span>
      </a>
    </div>

    <div class="reveal" style="font-size:17px;line-height:1.8;color:var(--mid);">
      <p>A half-day forum exploring policy priorities for Houston's economic future, featuring panels on energy transition, workforce development, and healthcare innovation.</p><p>Panelists include leaders from the energy sector, healthcare institutions, and city government. Topics include Houston's role in the national energy transition, workforce pipeline development, and emerging health technology investments.</p><p>This forum builds on CHF's decades of cross-sector convening experience, bringing together diverse stakeholders to shape actionable policy recommendations for the Houston region.</p>
    </div>

    <div class="event-map reveal">
      <h2>Location</h2>
      <div class="map-embed">
        <iframe src="https://www.google.com/maps?q=Partnership+Tower+701+Avenida+de+las+Americas+Houston+TX&output=embed" sandbox="allow-scripts allow-same-origin" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Event location map"></iframe>
      </div>
    </div>

    <div class="event-registration reveal" id="register">
      <h2>Register for This Event</h2>
      <p class="reg-sub">Secure your spot. All fields are required unless noted.</p>
      <form class="reg-form" action="#" method="post" aria-label="Event registration">
        <div class="form-row">
          <div>
            <label for="reg-first">First Name</label>
            <input type="text" id="reg-first" name="first_name" autocomplete="given-name" required>
          </div>
          <div>
            <label for="reg-last">Last Name</label>
            <input type="text" id="reg-last" name="last_name" autocomplete="family-name" required>
          </div>
        </div>
        <div>
          <label for="reg-email">Email Address</label>
          <input type="email" id="reg-email" name="email" autocomplete="email" required>
        </div>
        <div>
          <label for="reg-org">Organization <span style="color:var(--muted);font-weight:400;">(optional)</span></label>
          <input type="text" id="reg-org" name="organization" autocomplete="organization">
        </div>
        <button type="submit" class="reg-submit">Register Now &#8594;</button>
      </form>
      <p class="reg-or-external">Or register via <a href="#" target="_blank" rel="noopener noreferrer">Eventbrite</a></p>
    </div>
  </div>

  <div style="padding:0 var(--container-pad) 48px;max-width:900px;margin:auto;">
    <a href="chf_events_v4.html" class="reveal" style="display:inline-flex;align-items:center;gap:8px;font-weight:600;font-size:14px;color:var(--navy);text-decoration:none;transition:color 0.2s;">
      <span aria-hidden="true">&#8592;</span> Back to Events
    </a>
  </div>]]></content:encoded>
